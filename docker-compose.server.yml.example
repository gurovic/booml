services:
  postgres:
    container_name: booml-postgres
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: booml
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: YOUR_DB_PASSWORD
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d booml"]
      interval: 5s
      timeout: 3s
      retries: 20

  redis:
    container_name: booml-redis
    image: redis:7-alpine
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 20
    networks:
      default:
        aliases:
          - redis

  runner-vm:
    image: runner-vm:latest
    build:
      context: ./backend
      dockerfile: docker/Dockerfile
    command: ["true"]

  backend:
    container_name: booml-backend
    build:
      context: ./backend
      dockerfile: Dockerfile
    command: >
      sh -c "
        python manage.py migrate &&
        python manage.py runserver 0.0.0.0:8100
      "
    working_dir: /app
    volumes:
      - ./backend:/app
      - ./problem_data:/problem_data
      - /run/user/1001/docker.sock:/var/run/docker.sock
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      runner-vm:
        condition: service_started
    environment:
      DJANGO_SETTINGS_MODULE: core.settings
      SECRET_KEY: YOUR_SECRET_KEY_HERE
      DEBUG: "False"
      MODE: dev
      CAPTCHA_PROVIDER: turnstile
      TURNSTILE_SITE_KEY: 1x00000000000000000000AA
      TURNSTILE_SECRET_KEY: YOUR_TURNSTILE_SECRET
      DB_NAME: booml
      DB_USER: postgres
      DB_PASSWORD: YOUR_DB_PASSWORD
      DB_HOST: postgres
      DB_PORT: "5432"
      ALLOWED_HOSTS: booml.letovo.site,backend.booml.letovo.site,backend,localhost,127.0.0.1,10.8.45.1,10.8.52.11,95.167.212.23,llm.letovo.site
      CSRF_TRUSTED_ORIGINS: http://localhost:8101,http://booml.letovo.site,https://booml.letovo.site,http://10.8.45.1:8090,http://10.8.45.1:8092,http://10.8.52.11:8090,http://10.8.52.11:8092,http://95.167.212.23:8810,http://95.167.212.23:8090,http://llm.letovo.site:8090,http://llm.letovo.site:8810
      RUNTIME_EXECUTION_BACKEND: legacy
      RUNTIME_VM_BACKEND: docker
      PROBLEM_DATA_ROOT: /problem_data/problem_data
      RUNTIME_VM_HOST_ROOT: /home/booml/booml/backend
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/1
      CHANNEL_LAYER_REDIS_URL: redis://redis:6379/2
      RUNNER_USE_CELERY_QUEUE: "1"
      PROMETHEUS_URL: http://prometheus:9090

  celery:
    container_name: booml-celery
    build:
      context: ./backend
      dockerfile: Dockerfile
    command: >
      sh -c "
        celery -A runner.celery:app worker -l info
      "
    working_dir: /app
    volumes:
      - ./backend:/app
      - ./problem_data:/problem_data
      - /run/user/1001/docker.sock:/var/run/docker.sock
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      DJANGO_SETTINGS_MODULE: core.settings
      SECRET_KEY: YOUR_SECRET_KEY_HERE
      DEBUG: "False"
      MODE: dev
      DB_NAME: booml
      DB_USER: postgres
      DB_PASSWORD: YOUR_DB_PASSWORD
      DB_HOST: postgres
      DB_PORT: "5432"
      RUNTIME_VM_BACKEND: docker
      PROBLEM_DATA_ROOT: /problem_data/problem_data
      RUNTIME_VM_HOST_ROOT: /home/booml/booml/backend
      CELERY_BROKER_URL: redis://redis:6379/0
      CELERY_RESULT_BACKEND: redis://redis:6379/1
      CHANNEL_LAYER_LAYERS_URL: redis://redis:6379/2
      RUNNER_USE_CELERY_QUEUE: "1"
      DASHBOARD_CPU_SESSION_CAPACITY: "8"
      DASHBOARD_GPU_SESSION_CAPACITY: "1"

  frontend:
    container_name: booml-frontend
    image: node:18
    working_dir: /app
    command: sh -c "NODE_ENV=production npm run serve -- --host 0.0.0.0 --port 8101"
    volumes:
      - ./frontend:/app
      - frontend-node-modules:/app/node_modules
    environment:
      VUE_APP_API_BASE: /api
      VUE_APP_BACKEND_URL: http://backend:8100/
      VUE_APP_TURNSTILE_SITE_KEY: 1x00000000000000000000AA
      VUE_APP_DASHBOARD_URL: http://llm.letovo.site:8090/dashboard/
    depends_on:
      - backend

  dashboard:
    container_name: booml-dashboard
    image: node:18
    working_dir: /app
    command: >
      sh -c "
        npm install &&
        npm run serve -- --host 0.0.0.0 --port 8102
      "
    volumes:
      - ./dashboard:/app
      - dashboard-node-modules:/app/node_modules
    environment:
      VUE_APP_BACKEND_URL: http://llm.letovo.site:8090/
      VUE_APP_MAIN_APP_URL: http://llm.letovo.site:8090
    depends_on:
      - backend

  prometheus:
    container_name: booml-prometheus
    image: prom/prometheus:latest
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--storage.tsdb.retention.time=30d'
    restart: unless-stopped

  nginx:
    container_name: booml-nginx
    image: nginx:alpine
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./backend/staticfiles:/staticfiles:ro
      - ./backend/media:/media_files:ro
    ports:
      - "8090:8090"
      - "8092:8092"
      - "8810:8090"
    depends_on:
      - frontend
    restart: unless-stopped

volumes:
  frontend-node-modules:
  dashboard-node-modules:
  redis-data:
  postgres-data:
  prometheus-data:
